FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /source

COPY Directory.Build.props .
COPY src/SkullsLudo.Shared/SkullsLudo.Shared.csproj src/SkullsLudo.Shared/
COPY src/SkullsLudo.Evaluator/SkullsLudo.Evaluator.csproj src/SkullsLudo.Evaluator/
RUN dotnet restore src/SkullsLudo.Evaluator/SkullsLudo.Evaluator.csproj -r linux-x64

COPY src/SkullsLudo.Shared/ src/SkullsLudo.Shared/
COPY src/SkullsLudo.Evaluator/ src/SkullsLudo.Evaluator/
RUN dotnet publish src/SkullsLudo.Evaluator/SkullsLudo.Evaluator.csproj \
    -c Release \
    -r linux-x64 \
    --self-contained true \
    -p:PublishSingleFile=true \
    -o /app \
    --no-restore

FROM mcr.microsoft.com/dotnet/runtime-deps:10.0-noble-chiseled AS runtime
WORKDIR /app
COPY --from=build /app .

EXPOSE 50508

ENTRYPOINT ["./SkullsLudo.Evaluator"]
