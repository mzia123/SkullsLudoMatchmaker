{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Grpc": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Matchmaker": {
    "OpenMatch": {
      "QueryHost": "open-match-query",
      "QueryPort": 50503
    }
  }
}
