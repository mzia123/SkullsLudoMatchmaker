{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.Hosting": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Matchmaker": {
    "OpenMatch": {
      "FrontendHost": "open-match-frontend",
      "FrontendPort": 50504,
      "BackendHost": "open-match-backend",
      "BackendPort": 50505,
      "QueryHost": "open-match-query",
      "QueryPort": 50503
    },
    "Agones": {
      "AllocatorHost": "agones-allocator.agones-system.svc",
      "AllocatorPort": 443
    },
    "MatchFunction": {
      "Host": "skulls-ludo-matchfunction",
      "Port": 50502
    },
    "Director": {
      "LoopIntervalMs": 5000
    },
    "Queues": {
      "practice": {
        "Name": "practice",
        "Tag": "queue.practice",
        "MaxPlayers": 2,
        "MinPlayers": 2,
        "Timeout": "00:02:00",
        "DegradationSteps": []
      },
      "quickplay": {
        "Name": "quickplay",
        "Tag": "queue.quickplay",
        "MaxPlayers": 4,
        "MinPlayers": 2,
        "Timeout": "00:02:00",
        "DegradationSteps": [
          { "After": "00:00:05", "PlayerCount": 3 },
          { "After": "00:00:10", "PlayerCount": 2 }
        ]
      }
    }
  }
}
