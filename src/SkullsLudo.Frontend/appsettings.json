{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Matchmaker": {
    "TimeoutMinutes": 2,
    "OpenMatch": {
      "FrontendHost": "open-match-frontend.open-match.svc.cluster.local",
      "FrontendPort": 50504
    }
  }
}
